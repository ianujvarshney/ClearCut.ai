NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:3000

MONGO_URI=mongodb://localhost:27017/clearcut_ai
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=replace-with-strong-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=replace-with-strong-cookie-secret-at-least-32-chars

CLOUDINARY_CLOUD_NAME=clearcut_ai
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_PRO=your-stripe-pro-price-id
STRIPE_PRICE_BUSINESS=your-stripe-business-price-id

SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-smtp-password
EMAIL_FROM=ClearCut AI <no-reply@clearcut.ai>

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=500
UPLOAD_MAX_FILE_SIZE_MB=15
MAINTENANCE_MODE=false
