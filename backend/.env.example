# =========================
# Application Configuration
# =========================
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

APP_URL=http://localhost:3000
API_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:3000

# =========================
# Database Configuration
# =========================
MONGO_URI=mongodb://mongo:27017/clearcut_ai

# =========================
# Redis Configuration
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# =========================
# Authentication & Security
# =========================
JWT_ACCESS_SECRET=replace-with-64-char-access-secret
JWT_REFRESH_SECRET=replace-with-64-char-refresh-secret
COOKIE_SECRET=replace-with-64-char-cookie-secret

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# =========================
# AI Service Configuration
# =========================
AI_PROVIDER_ORDER=fastapi,clipdrop,mock
AI_INFERENCE_URL=http://ai-inference:8000
AI_SERVICE_JWT=replace-with-64-char-ai-service-token

AI_MODEL_DEFAULT=rmbg
AI_JOB_CONCURRENCY=3
AI_JOB_TIMEOUT_MS=120000

# =========================
# ClipDrop API
# =========================
CLIPDROP_API_URL=https://clipdrop-api.co/remove-background/v1
CLIPDROP_API_KEY=

# =========================
# Storage Configuration
# =========================
STORAGE_PROVIDER=local

OBJECT_STORAGE_BUCKET=clearcut-ai-dev
OBJECT_STORAGE_REGION=us-east-1

CDN_BASE_URL=
SIGNED_URL_TTL_SECONDS=300
TEMP_OBJECT_TTL_HOURS=24

# =========================
# Malware Scan
# =========================
MALWARE_SCAN_ENABLED=false

# =========================
# Monitoring & Metrics
# =========================
METRICS_ENABLED=true

# =========================
# Cloudinary Configuration
# =========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =========================
# Rate Limiting & Uploads
# =========================
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=500

UPLOAD_MAX_FILE_SIZE_MB=15

# =========================
# Maintenance
# =========================
MAINTENANCE_MODE=false
